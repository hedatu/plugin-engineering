server {
    server_name hwh.915500.xyz;

    root /var/www/hwh.915500.xyz;
    index index.html;

    location ^~ /.well-known/acme-challenge/ {
        default_type text/plain;
        alias /var/www/hwh.915500.xyz/.well-known/acme-challenge/;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    listen [::]:443 ssl; # managed by Certbot
    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/hwh.915500.xyz/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/hwh.915500.xyz/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = hwh.915500.xyz) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    listen [::]:80;
    server_name hwh.915500.xyz;
    return 404; # managed by Certbot


}