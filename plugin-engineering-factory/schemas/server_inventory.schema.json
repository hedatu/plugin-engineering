{
  "type": "object",
  "required": [
    "checked_at",
    "inventory_root",
    "current_local_ssh_config_path_redacted",
    "current_local_ssh_aliases_present",
    "sensitive_files_detected",
    "sensitive_file_count",
    "server_count",
    "servers"
  ],
  "properties": {
    "checked_at": {
      "type": "string",
      "minLength": 10
    },
    "inventory_root": {
      "type": "string",
      "minLength": 3
    },
    "current_local_ssh_config_path_redacted": {
      "type": "string",
      "minLength": 3
    },
    "current_local_ssh_aliases_present": {
      "type": "boolean"
    },
    "sensitive_files_detected": {
      "type": "boolean"
    },
    "sensitive_file_count": {
      "type": "integer",
      "minimum": 0
    },
    "server_count": {
      "type": "integer",
      "minimum": 0
    },
    "servers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "server_id",
          "droplet_name",
          "region",
          "role",
          "ip_redacted",
          "ssh_user",
          "ssh_key_path_redacted",
          "ssh_config_detected",
          "current_local_alias_present",
          "login_method",
          "notes_files_detected",
          "sensitive_files_detected",
          "recommended_role",
          "should_connect_now",
          "blockers"
        ],
        "properties": {
          "server_id": {
            "type": "string",
            "enum": ["california", "singapore"]
          },
          "droplet_name": {
            "type": "string",
            "minLength": 3
          },
          "region": {
            "type": "string",
            "enum": ["california", "singapore"]
          },
          "role": {
            "type": "string",
            "enum": ["primary_factory_server", "backup_or_staging"]
          },
          "ip_redacted": {
            "type": ["string", "null"]
          },
          "ssh_user": {
            "type": "string",
            "minLength": 1
          },
          "ssh_key_path_redacted": {
            "type": ["string", "null"]
          },
          "ssh_config_detected": {
            "type": "boolean"
          },
          "current_local_alias_present": {
            "type": "boolean"
          },
          "login_method": {
            "type": "string",
            "minLength": 3
          },
          "notes_files_detected": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "sensitive_files_detected": {
            "type": "boolean"
          },
          "recommended_role": {
            "type": "string",
            "enum": ["primary_factory_server", "backup_or_staging"]
          },
          "should_connect_now": {
            "type": "boolean"
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}

