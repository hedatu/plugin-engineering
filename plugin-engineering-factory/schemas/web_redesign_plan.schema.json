{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "run_id",
    "product_key",
    "generated_at",
    "source_run_id",
    "payment_mode",
    "production_payment_status",
    "objectives",
    "redesigned_pages",
    "information_architecture",
    "generated_files",
    "non_goals_preserved",
    "next_step"
  ],
  "properties": {
    "stage": { "type": "string", "enum": ["PREMIUM_WEB_REDESIGN_PLAN"] },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "run_id": { "type": "string", "minLength": 1 },
    "product_key": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "source_run_id": { "type": "string", "minLength": 1 },
    "current_primary_environment": { "type": "string" },
    "payment_mode": { "type": "string", "minLength": 1 },
    "production_payment_status": { "type": "string", "minLength": 1 },
    "objectives": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "redesigned_pages": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "information_architecture": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "generated_files": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "non_goals_preserved": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "next_step": { "type": "string", "minLength": 1 },
    "redaction_checks": { "type": "object" }
  }
}
