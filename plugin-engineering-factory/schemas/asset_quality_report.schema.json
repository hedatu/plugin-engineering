{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "run_id",
    "render_status",
    "assets_checked",
    "passed_checks",
    "warnings",
    "blockers",
    "real_ui_traceability_passed",
    "dimension_validation_passed",
    "next_step"
  ],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["ASSET_QA"]
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped"]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "render_status": {
      "type": "string",
      "minLength": 1
    },
    "assets_checked": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "passed_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "real_ui_traceability_passed": {
      "type": "boolean"
    },
    "dimension_validation_passed": {
      "type": "boolean"
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    }
  }
}
