{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "run_id",
    "selected",
    "build_recommendation",
    "reason",
    "confidence_score",
    "evidence_quality_score",
    "testability_score",
    "portfolio_overlap_score",
    "blockers",
    "next_step",
    "redaction_checks"
  ],
  "properties": {
    "stage": { "type": "string", "enum": ["STRATEGY_V2_NEXT_CANDIDATE"] },
    "status": { "type": "string", "enum": ["passed", "skipped", "failed"] },
    "run_id": { "type": "string" },
    "selected": { "type": "boolean" },
    "build_recommendation": { "type": "string", "enum": ["build", "research_more", "skip"] },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "next_step": { "type": "string" },
    "redaction_checks": { "type": "object" }
  }
}
