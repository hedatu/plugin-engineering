{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["stage", "status", "events", "privacy_default", "redaction_checks"],
  "properties": {
    "stage": { "type": "string", "enum": ["MARKET_TEST_METRICS_SPEC"] },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "events": { "type": "array", "items": { "type": "object" } },
    "privacy_default": { "type": "string" },
    "redaction_checks": { "type": "object" }
  }
}
