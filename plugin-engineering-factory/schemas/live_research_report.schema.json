{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "generated_at",
    "requested_mode",
    "resolved_mode",
    "source_mode",
    "sitemap_requests",
    "search_requests",
    "listing_requests",
    "support_requests",
    "github_issue_requests",
    "fallback_to_fixture",
    "fallback_used",
    "fallback_reason",
    "fallback_reason_type",
    "candidates"
  ],
  "properties": {
    "stage": { "type": "string", "enum": ["LIVE_DISCOVERY_ADAPTER"] },
    "status": { "type": "string", "enum": ["skipped", "running", "passed", "failed"] },
    "generated_at": { "type": "string" },
    "requested_mode": { "type": "string" },
    "resolved_mode": { "type": "string" },
    "source_mode": { "type": "string" },
    "sitemap_requests": { "type": "array", "items": { "type": "object" } },
    "search_requests": { "type": "array", "items": { "type": "object" } },
    "listing_requests": { "type": "array", "items": { "type": "object" } },
    "support_requests": { "type": "array", "items": { "type": "object" } },
    "github_issue_requests": { "type": "array", "items": { "type": "object" } },
    "fallback_to_fixture": { "type": "boolean" },
    "fallback_used": { "type": "boolean" },
    "fallback_reason": { "type": ["string", "null"] },
    "fallback_reason_type": { "type": ["string", "null"] },
    "candidates": { "type": "array", "items": { "type": "object" } }
  }
}
