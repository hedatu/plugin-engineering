{
  "type": "object",
  "required": [
    "checked_at",
    "server_id",
    "region",
    "role",
    "ip_redacted",
    "ssh_user",
    "ssh_key_path_redacted",
    "ssh_alias",
    "current_local_alias_present",
    "login_method",
    "command_mode",
    "commands_run",
    "connected",
    "whoami",
    "id",
    "hostname",
    "uname",
    "uptime",
    "disk_usage",
    "memory",
    "node_version",
    "npm_version",
    "docker_version",
    "docker_compose_version",
    "nginx_version",
    "caddy_version",
    "blockers"
  ],
  "properties": {
    "checked_at": {
      "type": "string",
      "minLength": 10
    },
    "server_id": {
      "type": "string",
      "enum": ["california", "singapore"]
    },
    "region": {
      "type": "string",
      "enum": ["california", "singapore"]
    },
    "role": {
      "type": "string",
      "enum": ["primary_factory_server", "backup_or_staging"]
    },
    "ip_redacted": {
      "type": ["string", "null"]
    },
    "ssh_user": {
      "type": "string",
      "minLength": 1
    },
    "ssh_key_path_redacted": {
      "type": ["string", "null"]
    },
    "ssh_alias": {
      "type": "string",
      "minLength": 3
    },
    "current_local_alias_present": {
      "type": "boolean"
    },
    "login_method": {
      "type": "string",
      "minLength": 3
    },
    "command_mode": {
      "type": "string",
      "enum": ["read_only"]
    },
    "commands_run": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "connected": {
      "type": "boolean"
    },
    "whoami": {
      "type": ["string", "null"]
    },
    "id": {
      "type": ["string", "null"]
    },
    "hostname": {
      "type": ["string", "null"]
    },
    "uname": {
      "type": ["string", "null"]
    },
    "uptime": {
      "type": ["string", "null"]
    },
    "disk_usage": {
      "type": ["string", "null"]
    },
    "memory": {
      "type": ["string", "null"]
    },
    "node_version": {
      "type": ["string", "null"]
    },
    "npm_version": {
      "type": ["string", "null"]
    },
    "docker_version": {
      "type": ["string", "null"]
    },
    "docker_compose_version": {
      "type": ["string", "null"]
    },
    "nginx_version": {
      "type": ["string", "null"]
    },
    "caddy_version": {
      "type": ["string", "null"]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
