{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "run_id",
    "run_type",
    "source_run_id",
    "item_id",
    "publisher_id",
    "package_sha256",
    "manifest_version",
    "current_sandbox_item_version",
    "version_uploadable",
    "immutable_run_verified",
    "promotion_plan_verified",
    "listing_package_verified",
    "browser_smoke_verified",
    "screenshot_manifest_verified",
    "policy_gate_verified",
    "listing_quality_gate_passed",
    "asset_qa_passed",
    "store_release_package_passed",
    "premium_feel_score",
    "human_visual_review_passed",
    "paid_disclosure_passed",
    "pre_publish_asset_gate",
    "write_approval_present",
    "write_approval_valid",
    "latest_approval_package_sha256",
    "current_package_sha256",
    "approval_matches_current_package",
    "latest_upload_blocker",
    "upload_allowed",
    "publish_allowed",
    "next_step",
    "blockers",
    "redaction_checks"
  ],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["SANDBOX_PREFLIGHT"]
    },
    "status": {
      "type": "string",
      "enum": ["blocked", "passed_read_only", "passed", "failed"]
    },
    "run_id": { "type": "string" },
    "run_type": { "type": "string", "enum": ["sandbox_validation"] },
    "source_run_id": { "type": ["string", "null"] },
    "item_id": { "type": ["string", "null"] },
    "publisher_id": { "type": ["string", "null"] },
    "package_sha256": { "type": "string" },
    "manifest_version": { "type": ["string", "null"] },
    "current_sandbox_item_version": { "type": ["string", "null"] },
    "version_uploadable": { "type": "boolean" },
    "immutable_run_verified": { "type": "boolean" },
    "promotion_plan_verified": { "type": "boolean" },
    "listing_package_verified": { "type": "boolean" },
    "browser_smoke_verified": { "type": "boolean" },
    "screenshot_manifest_verified": { "type": "boolean" },
    "policy_gate_verified": { "type": "boolean" },
    "listing_quality_gate_passed": { "type": "boolean" },
    "asset_qa_passed": { "type": "boolean" },
    "store_release_package_passed": { "type": "boolean" },
    "premium_feel_score": { "type": "number" },
    "human_visual_review_passed": { "type": "boolean" },
    "paid_disclosure_passed": { "type": "boolean" },
    "pre_publish_asset_gate": { "type": "object" },
    "product_acceptance_status": { "type": "string" },
    "functional_test_coverage_score": { "type": ["number", "null"] },
    "write_approval_present": { "type": "boolean" },
    "write_approval_valid": { "type": "boolean" },
    "latest_approval_package_sha256": { "type": ["string", "null"] },
    "current_package_sha256": { "type": "string" },
    "approval_matches_current_package": { "type": "boolean" },
    "latest_upload_blocker": { "type": ["string", "null"] },
    "upload_allowed": { "type": "boolean" },
    "publish_allowed": { "type": "boolean" },
    "next_step": { "type": "string" },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "redaction_checks": { "type": "object" }
  }
}
