{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["stage", "status", "candidate_name", "wedge_name", "market_test_mode_enabled", "build_time_budget_hours", "price_test", "free_limit", "success_metrics", "kill_criteria", "next_step", "redaction_checks"],
  "properties": {
    "stage": { "type": "string", "enum": ["MARKET_TEST_PLAN"] },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "candidate_name": { "type": "string" },
    "wedge_name": { "type": "string" },
    "market_test_mode_enabled": { "type": "boolean" },
    "build_time_budget_hours": { "type": "number" },
    "price_test": { "type": "string" },
    "free_limit": { "type": "string" },
    "success_metrics": { "type": "array", "items": { "type": "string" } },
    "kill_criteria": { "type": "array", "items": { "type": "string" } },
    "next_step": { "type": "string" },
    "redaction_checks": { "type": "object" }
  }
}
