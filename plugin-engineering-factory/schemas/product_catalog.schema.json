{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "generated_at",
    "last_updated_at",
    "products"
  ],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["PRODUCT_CATALOG_V2"]
    },
    "status": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "last_updated_at": {
      "type": "string"
    },
    "last_updated_by_command": {
      "type": "string"
    },
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "productKey",
          "slug",
          "name",
          "shortName",
          "tagline",
          "oneSentenceValue",
          "category",
          "targetUser",
          "version",
          "chromeExtensionId",
          "chromeWebStoreItemId",
          "chromeWebStoreUrl",
          "status",
          "siteUrl",
          "detailPagePath",
          "pricingPagePath",
          "installUrl",
          "supportUrl",
          "privacyUrl",
          "changelogUrl",
          "docsUrl",
          "paymentProvider",
          "productKeyOnPaySite",
          "planKeys",
          "defaultPlanKey",
          "priceLabel",
          "freeLimit",
          "proFeatures",
          "freeFeatures",
          "featureKeys",
          "checkoutMode",
          "entitlementStatus",
          "paymentConfigStatus",
          "listingAssetsPath",
          "remotionAssetsPath",
          "marketTestStatus",
          "releaseRunId"
        ],
        "properties": {
          "productKey": { "type": "string", "minLength": 1 },
          "slug": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "shortName": { "type": "string", "minLength": 1 },
          "tagline": { "type": "string", "minLength": 1 },
          "oneSentenceValue": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "targetUser": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "chromeExtensionId": { "type": "string", "minLength": 1 },
          "chromeWebStoreItemId": { "type": "string", "minLength": 1 },
          "chromeWebStoreUrl": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["draft", "generated", "staged", "published", "market_testing", "retired"]
          },
          "siteUrl": { "type": "string", "minLength": 1 },
          "detailPagePath": { "type": "string", "minLength": 1 },
          "pricingPagePath": { "type": "string", "minLength": 1 },
          "installUrl": { "type": "string", "minLength": 1 },
          "supportUrl": { "type": "string", "minLength": 1 },
          "privacyUrl": { "type": "string", "minLength": 1 },
          "changelogUrl": { "type": "string", "minLength": 1 },
          "docsUrl": { "type": "string", "minLength": 1 },
          "paymentProvider": {
            "type": "string",
            "enum": ["hwh_waffo"]
          },
          "productKeyOnPaySite": { "type": "string", "minLength": 1 },
          "planKeys": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "defaultPlanKey": { "type": "string", "minLength": 1 },
          "priceLabel": { "type": "string", "minLength": 1 },
          "freeLimit": { "type": "integer", "minimum": 0 },
          "proFeatures": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "freeFeatures": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "featureKeys": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "checkoutMode": {
            "type": "string",
            "enum": ["disabled", "test", "live"]
          },
          "entitlementStatus": { "type": "string", "minLength": 1 },
          "paymentConfigStatus": { "type": "string", "minLength": 1 },
          "listingAssetsPath": { "type": "string", "minLength": 1 },
          "remotionAssetsPath": { "type": "string", "minLength": 1 },
          "marketTestStatus": { "type": "string", "minLength": 1 },
          "releaseRunId": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
