{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "run_id",
    "decision",
    "note",
    "recorded_at",
    "acceptance_status_at_review",
    "repair_suggestions",
    "next_step",
    "redaction_checks"
  ],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["HUMAN_PRODUCT_REVIEW"]
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "run_id": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": ["passed", "revise", "blocked", "kill"]
    },
    "note": { "type": "string" },
    "recorded_at": { "type": "string" },
    "acceptance_status_at_review": {
      "type": "string",
      "enum": ["passed", "revise", "blocked", "kill"]
    },
    "repair_suggestions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_step": { "type": "string" },
    "redaction_checks": { "type": "object" }
  }
}
