{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "run_id",
    "candidate_id",
    "candidate_name",
    "wedge_name",
    "prior_decision",
    "manual_evidence_count",
    "strong_manual_evidence_count",
    "evidence_summary",
    "updated_evidence_quality_score",
    "updated_wedge_clarity_score",
    "updated_install_intent_score",
    "updated_local_only_preference_score",
    "updated_text_first_preference_score",
    "updated_portfolio_overlap_score",
    "updated_testability_score",
    "updated_permission_risk",
    "updated_compliance_risk",
    "final_decision",
    "final_reason",
    "next_step",
    "redaction_checks"
  ],
  "properties": {
    "stage": { "type": "string", "enum": ["CANDIDATE_RESCORE_WITH_MANUAL_EVIDENCE"] },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "run_id": { "type": "string" },
    "candidate_id": { "type": "string" },
    "candidate_name": { "type": "string" },
    "wedge_name": { "type": "string" },
    "prior_decision": { "type": "string" },
    "manual_evidence_count": { "type": "integer" },
    "strong_manual_evidence_count": { "type": "integer" },
    "evidence_summary": { "type": "object" },
    "updated_evidence_quality_score": { "type": "number" },
    "updated_wedge_clarity_score": { "type": "number" },
    "updated_install_intent_score": { "type": "number" },
    "updated_local_only_preference_score": { "type": "number" },
    "updated_text_first_preference_score": { "type": "number" },
    "updated_portfolio_overlap_score": { "type": "number" },
    "updated_testability_score": { "type": "number" },
    "updated_permission_risk": { "type": "string" },
    "updated_compliance_risk": { "type": "string" },
    "final_decision": {
      "type": "string",
      "enum": ["human_candidate_review_ready", "keep_waiting_for_evidence", "skip"]
    },
    "final_reason": { "type": "string" },
    "next_step": { "type": "string" },
    "redaction_checks": { "type": "object" }
  }
}
