{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "run_id",
    "product_name",
    "overall_polish_score",
    "premium_ready",
    "items",
    "blockers",
    "next_step"
  ],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["PRODUCT_POLISH_CHECKLIST"]
    },
    "status": {
      "type": "string",
      "enum": ["passed", "skipped", "failed"]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "product_name": {
      "type": "string",
      "minLength": 1
    },
    "overall_polish_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "premium_ready": {
      "type": "boolean"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_step": {
      "type": "string",
      "minLength": 1
    }
  }
}
