{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "checked_at",
    "env_sources_checked",
    "publisher_id_present",
    "item_id_present",
    "google_application_credentials_present",
    "google_application_credentials_file_exists",
    "service_account_json_present",
    "oauth_refresh_token_present",
    "credential_mode",
    "proxy_configured",
    "proxy_source",
    "proxy_url_redacted",
    "node_can_probe_oauth2",
    "node_can_probe_cws",
    "token_self_test_attempted",
    "token_self_test_status",
    "fetch_status_attempted",
    "fetch_status_status",
    "current_review_state",
    "findings",
    "required_fixes"
  ],
  "properties": {
    "stage": {
      "type": "string",
      "enum": ["REVIEW_WATCH_CREDENTIALS_DOCTOR"]
    },
    "status": {
      "type": "string",
      "enum": ["passed", "warning", "failed"]
    },
    "checked_at": {
      "type": "string"
    },
    "env_sources_checked": {
      "type": "object"
    },
    "publisher_id_present": {
      "type": "boolean"
    },
    "item_id_present": {
      "type": "boolean"
    },
    "google_application_credentials_present": {
      "type": "boolean"
    },
    "google_application_credentials_file_exists": {
      "type": "boolean"
    },
    "service_account_json_present": {
      "type": "boolean"
    },
    "oauth_refresh_token_present": {
      "type": "boolean"
    },
    "credential_mode": {
      "type": "string",
      "enum": ["service_account_file", "service_account_json", "oauth_refresh_token", "missing"]
    },
    "proxy_configured": {
      "type": "boolean"
    },
    "proxy_source": {
      "type": ["string", "null"]
    },
    "proxy_url_redacted": {
      "type": ["string", "null"]
    },
    "node_can_probe_oauth2": {
      "type": "boolean"
    },
    "node_can_probe_cws": {
      "type": "boolean"
    },
    "token_self_test_attempted": {
      "type": "boolean"
    },
    "token_self_test_status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped"]
    },
    "fetch_status_attempted": {
      "type": "boolean"
    },
    "fetch_status_status": {
      "type": "string",
      "enum": ["passed", "failed", "skipped"]
    },
    "current_review_state": {
      "type": ["string", "null"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_fixes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
