{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["stage", "status", "candidate_name", "wedge_name", "free_limit", "lifetime_unlock_price", "rules", "redaction_checks"],
  "properties": {
    "stage": { "type": "string", "enum": ["VALUE_FIRST_PAYWALL_RULES"] },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "candidate_name": { "type": "string" },
    "wedge_name": { "type": "string" },
    "free_limit": { "type": "string" },
    "lifetime_unlock_price": { "type": "string" },
    "rules": { "type": "array", "items": { "type": "string" } },
    "redaction_checks": { "type": "object" }
  }
}
