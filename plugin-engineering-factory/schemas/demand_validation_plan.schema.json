{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "stage",
    "status",
    "run_id",
    "candidate_id",
    "candidate_name",
    "wedge_name",
    "hypothesis",
    "target_users",
    "validation_questions",
    "interview_script",
    "survey_questions",
    "landing_page_copy_draft",
    "manual_workflow_test",
    "success_criteria",
    "failure_criteria",
    "minimum_evidence_needed",
    "next_step",
    "redaction_checks"
  ],
  "properties": {
    "stage": { "type": "string", "enum": ["DEMAND_VALIDATION_PLAN"] },
    "status": { "type": "string", "enum": ["passed", "failed"] },
    "run_id": { "type": "string" },
    "candidate_id": { "type": "string" },
    "candidate_name": { "type": "string" },
    "wedge_name": { "type": "string" },
    "hypothesis": { "type": "string" },
    "target_users": { "type": "array", "items": { "type": "string" } },
    "validation_questions": { "type": "array", "items": { "type": "string" } },
    "interview_script": { "type": "array", "items": { "type": "string" } },
    "survey_questions": { "type": "array", "items": { "type": "string" } },
    "landing_page_copy_draft": { "type": "object" },
    "manual_workflow_test": { "type": "object" },
    "success_criteria": { "type": "array", "items": { "type": "string" } },
    "failure_criteria": { "type": "array", "items": { "type": "string" } },
    "minimum_evidence_needed": { "type": "array", "items": { "type": "string" } },
    "next_step": { "type": "string" },
    "redaction_checks": { "type": "object" }
  }
}
