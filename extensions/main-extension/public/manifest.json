{
  "manifest_version": 3,
  "name": "Membership MVP Extension",
  "description": "Chrome MV3 membership extension wired to Supabase + Waffo webhook flow.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://api.waffo.ai/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Membership",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "assets/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

